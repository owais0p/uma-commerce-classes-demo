---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="About Us" description="Learn about the journey of Uma Commerce Classes and our founder, Anuja Mittal Ma'am (Uma Ma'am). Discover our teaching philosophy in Kota.">
  <Navbar />
  
  <main>
    <!-- Page Header -->
    <section class="bg-primary text-white py-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-secondary rounded-full filter blur-3xl"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
        <h1 class="text-4xl md:text-6xl font-black mb-6 uppercase tracking-tight">About <span class="text-secondary">Us</span></h1>
        <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed">
          The story of passion, dedication, and excellence in commerce education.
        </p>
      </div>
    </section>

    <!-- About Uma Ma'am -->
    <section class="py-24 bg-white overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div class="relative">
            <div class="aspect-[4/5] bg-gray-100 rounded-[3rem] overflow-hidden border-8 border-white shadow-2xl relative z-10 flex items-center justify-center">
              <span class="text-[12rem] md:text-[15rem] grayscale opacity-20">👩‍🏫</span>
              <!-- This would be Anuja Mittal Ma'am's Photo -->
              <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"></div>
              <div class="absolute bottom-10 left-10 text-white">
                <p class="text-2xl font-black tracking-tight">Anuja Mittal Ma'am</p>
                <p class="text-secondary font-bold uppercase tracking-widest text-sm">Founder & Lead Educator</p>
              </div>
            </div>
            <!-- Decorative elements -->
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-secondary/20 rounded-full filter blur-2xl -z-0"></div>
            <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-primary/10 rounded-full filter blur-3xl -z-0"></div>
          </div>
          
          <div>
            <h2 class="text-3xl md:text-5xl font-black text-primary mb-8 uppercase leading-tight">About <br /><span class="text-secondary italic font-serif normal-case">Uma Ma'am</span></h2>
            <p class="text-gray-600 text-lg mb-6 leading-relaxed">
              Anuja Mittal Ma'am, popularly known as <strong>Uma Ma'am</strong> among her students, is a visionary educator with years of experience in coaching commerce students for board exams.
            </p>
            <p class="text-gray-600 text-lg mb-8 leading-relaxed">
              Her teaching style is characterized by <strong>clarity, patience, and a deep understanding</strong> of the challenges students face in subjects like Accountancy and Economics. She believes that every student has the potential to be a topper if given the right direction and environment.
            </p>
            
            <div class="bg-primary/5 p-8 rounded-3xl border-l-4 border-secondary italic text-primary font-medium text-lg leading-relaxed">
              "My goal is not just to help students pass exams, but to instill a lifelong habit of excellence and conceptual thinking in them."
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Teaching Philosophy -->
    <section class="py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-black text-primary mb-4 uppercase tracking-tight">Our Philosophy</h2>
          <p class="text-gray-500 max-w-2xl mx-auto">We follow a structured approach to ensure 360-degree development of our students.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100 hover:-translate-y-2 transition-transform">
            <div class="text-4xl mb-6">📚</div>
            <h3 class="text-xl font-bold text-primary mb-4">Conceptual Clarity</h3>
            <p class="text-gray-600 leading-relaxed text-sm">We don't believe in rote learning. We ensure students understand the 'Why' behind every accounting entry and economic principle.</p>
          </div>
          <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100 hover:-translate-y-2 transition-transform">
            <div class="text-4xl mb-6">🎯</div>
            <h3 class="text-xl font-bold text-primary mb-4">Exam-Oriented Practice</h3>
            <p class="text-gray-600 leading-relaxed text-sm">Regular solving of sample papers, previous year questions, and time-bound tests to build exam temperament.</p>
          </div>
          <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100 hover:-translate-y-2 transition-transform">
            <div class="text-4xl mb-6">🌱</div>
            <h3 class="text-xl font-bold text-primary mb-4">Individual Growth</h3>
            <p class="text-gray-600 leading-relaxed text-sm">Personal monitoring of each student's progress and regular feedback sessions with parents for holistic growth.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Institute Story -->
    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-black text-primary mb-12 uppercase tracking-tight">The Institute</h2>
        <div class="aspect-video bg-primary/5 rounded-[3rem] border-2 border-dashed border-primary/20 flex items-center justify-center mb-12 relative overflow-hidden group">
          <span class="text-6xl group-hover:scale-110 transition-transform">🏢</span>
          <div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-colors"></div>
        </div>
        <div class="prose prose-lg mx-auto text-gray-600 text-left">
          <p>
            Located at <strong>Uma Grah, New Post Office Road, Kota</strong>, our institute provides a focused and comfortable environment for learning. Equipped with air-conditioned classrooms and modern teaching aids, we ensure that students can study without any distractions.
          </p>
          <p>
            From our humble beginnings, we have grown into one of Kota's most trusted names for commerce coaching, thanks to the consistent results of our students and the trust of parents.
          </p>
        </div>
        <div class="mt-16">
          <a href={`${base}/contact`} class="bg-secondary text-primary px-12 py-4 rounded-xl font-black text-lg hover:bg-primary hover:text-white transition-all shadow-xl">
            Visit Our Institute
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FloatingWhatsApp />
</Layout>
