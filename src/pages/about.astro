---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="The Institute" description="Discover the story of Uma Commerce Classes and the teaching philosophy of Anuja Mittal Ma'am (Uma Ma'am) in Kota.">
  <Navbar />
  
  <main class="dark:bg-[#0f1923] transition-colors duration-300">
    <!-- Page Header -->
    <section class="bg-primary text-white py-24 relative overflow-hidden dark:bg-[#0a1628]">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent rounded-full filter blur-3xl"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10 space-y-4">
        <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Our Legacy</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading uppercase tracking-tight">The <span class="text-accent italic font-serif normal-case">Institute</span></h1>
        <div class="w-20 h-1 bg-accent mx-auto mt-6"></div>
        <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed pt-4">
          A tradition of excellence, powered by passion and dedicated commerce mentorship.
        </p>
      </div>
    </section>

    <!-- Founder Spotlight -->
    <section class="section-padding bg-white overflow-hidden dark:bg-[#0f1923]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div class="relative">
            <div class="aspect-[4/5] bg-bg-light rounded-[3rem] overflow-hidden border-[16px] border-white shadow-2xl relative z-10 flex items-center justify-center group dark:bg-[#1a2332] dark:border-gray-800">
              <span class="text-[12rem] opacity-20 transition-opacity duration-700">👩‍🏫</span>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-12 left-12 text-white">
                <p class="text-3xl font-bold font-heading tracking-tight">Anuja Mittal Ma'am</p>
                <p class="text-accent font-bold uppercase tracking-[0.2em] text-[10px] mt-1">Founder & Chief Mentor</p>
              </div>
            </div>
            <!-- Decorative elite rings -->
            <div class="absolute -top-12 -left-12 w-48 h-48 border border-accent/20 rounded-full z-[-1]"></div>
            <div class="absolute -bottom-12 -right-12 w-64 h-64 border-2 border-primary/5 rounded-full z-[-1]"></div>
          </div>
          
          <div class="space-y-8">
            <div class="space-y-2">
               <p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px]">Academic Visionary</p>
               <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight uppercase dark:text-white">Meet <span class="italic font-serif normal-case text-accent">Uma Ma'am</span></h2>
            </div>
            <p class="text-text-gray text-lg leading-relaxed dark:text-gray-400">
              Anuja Mittal Ma'am, widely revered as <strong>Uma Ma'am</strong>, is more than an educator. She is a mentor who has redefined how commerce is taught in Kota.
            </p>
            <p class="text-text-gray text-lg leading-relaxed dark:text-gray-400">
              With an unwavering focus on <strong>conceptual depth</strong>, she has successfully mentored hundreds of students to achieve perfect or near-perfect scores in Accountancy and Economics. Her philosophy is simple: when you master the logic, the marks follow.
            </p>
            
            <div class="bg-primary p-10 rounded-[2rem] text-white italic font-medium text-lg leading-relaxed relative overflow-hidden shadow-xl dark:bg-[#0a1628]">
              <div class="absolute top-0 right-0 p-6 text-accent/20 text-6xl font-serif">"</div>
              <p class="relative z-10">
                "We don't just prepare students for exams; we prepare them for a lifetime of analytical excellence. Excellence at Uma Commerce Classes is a non-negotiable habit."
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy Grid -->
    <section class="section-padding bg-bg-light dark:bg-[#0a1628] isolation-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 space-y-3">
          <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">The Core Pillars</p>
          <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight dark:text-white">Our Teaching Philosophy</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {[
            { icon: "📜", title: "Conceptual Purity", desc: "No shortcuts. We dive deep into the 'Why' of every financial standard and economic model." },
            { icon: "🎯", title: "Board Precision", desc: "Rigorous alignment with latest board patterns, ensuring zero surprises on exam day." },
            { icon: "💎", title: "Personalized Mentorship", desc: "Small batches ensuring every student receives the focus they deserve." }
          ].map(item => (
            <div class="bg-white p-12 rounded-[2rem] shadow-sm hover:shadow-xl transition-all border border-gray-100 group dark:bg-[#1a2332] dark:border-gray-800 card">
              <div class="text-5xl mb-8 transition-opacity duration-300 inline-block">{item.icon}</div>
              <h4 class="text-xl font-bold text-primary mb-4 font-heading dark:text-white">{item.title}</h4>
              <p class="text-sm text-text-gray leading-relaxed dark:text-gray-400">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Infrastructure -->
    <section class="section-padding bg-white dark:bg-[#0f1923] isolation-auto">
      <div class="max-w-5xl mx-auto px-4 text-center space-y-8">
        <h2 class="text-3xl font-bold text-primary font-heading tracking-tight uppercase dark:text-white">Our Campus</h2>
        <p class="text-text-gray text-lg leading-relaxed dark:text-gray-400">
          Comfortable AC classrooms at Uma Grah,<br />
          New Post Office Road, Kota.
        </p>
        
        <div class="pt-8">
          <a href={`${base}/contact`} class="btn-gold px-12 py-4 text-lg">
            Visit Us
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
