---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import CourseCard from '../components/CourseCard.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="Courses" description="Explore our comprehensive commerce courses for 11th and 12th standard. Specializing in Accountancy, Business Studies, and Economics.">
  <Navbar />
  
  <main>
    <!-- Page Header -->
    <section class="bg-primary text-white py-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-secondary rounded-full filter blur-3xl"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
        <h1 class="text-4xl md:text-6xl font-black mb-6 uppercase tracking-tight">Our <span class="text-secondary">Courses</span></h1>
        <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed">
          Detailed curriculum designed to build strong foundations and achieve top scores in board exams.
        </p>
      </div>
    </section>

    <!-- Detailed Courses -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-24">
          <!-- Accountancy -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="order-2 lg:order-1">
              <div class="inline-block bg-primary text-secondary px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest mb-4">Core Subject</div>
              <h2 class="text-3xl md:text-4xl font-black text-primary mb-6 uppercase">Accountancy</h2>
              <p class="text-gray-600 mb-8 leading-relaxed text-lg">
                Accountancy is the backbone of commerce. We simplify complex entry systems and financial analysis with real-world examples.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
                  <h4 class="font-black text-primary mb-2 italic">Class 11th</h4>
                  <ul class="text-sm text-gray-500 space-y-2">
                    <li>• Introduction to Accounting</li>
                    <li>• Journal & Ledger</li>
                    <li>• Trial Balance & Errors</li>
                    <li>• Financial Statements</li>
                  </ul>
                </div>
                <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
                  <h4 class="font-black text-primary mb-2 italic">Class 12th</h4>
                  <ul class="text-sm text-gray-500 space-y-2">
                    <li>• Partnership Accounts</li>
                    <li>• Company Accounts (Shares)</li>
                    <li>• Cash Flow Statements</li>
                    <li>• Ratio Analysis</li>
                  </ul>
                </div>
              </div>
              <a href={`${base}/contact`} class="inline-block bg-secondary text-primary px-8 py-3 rounded-xl font-black hover:bg-primary hover:text-white transition-all shadow-lg">
                Download Full Syllabus
              </a>
            </div>
            <div class="order-1 lg:order-2 bg-primary/5 rounded-[3rem] p-12 flex items-center justify-center border border-primary/10">
              <span class="text-[10rem] md:text-[15rem] drop-shadow-2xl">📊</span>
            </div>
          </div>

          <!-- Business Studies -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="bg-secondary/5 rounded-[3rem] p-12 flex items-center justify-center border border-secondary/10">
              <span class="text-[10rem] md:text-[15rem] drop-shadow-2xl">🏢</span>
            </div>
            <div>
              <div class="inline-block bg-primary text-secondary px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest mb-4">Theory & Case Studies</div>
              <h2 class="text-3xl md:text-4xl font-black text-primary mb-6 uppercase">Business Studies</h2>
              <p class="text-gray-600 mb-8 leading-relaxed text-lg">
                More than just theory! We focus on management principles and business environment through the lens of modern corporate world.
              </p>
              <div class="space-y-4 mb-8">
                <div class="flex items-center space-x-4 bg-white p-4 rounded-xl shadow-sm border border-gray-50">
                  <span class="bg-secondary/20 p-2 rounded-lg">💡</span>
                  <span class="font-bold text-gray-700">Mnemonics for long answers</span>
                </div>
                <div class="flex items-center space-x-4 bg-white p-4 rounded-xl shadow-sm border border-gray-50">
                  <span class="bg-secondary/20 p-2 rounded-lg">🔎</span>
                  <span class="font-bold text-gray-700">Detailed Case Study Analysis</span>
                </div>
                <div class="flex items-center space-x-4 bg-white p-4 rounded-xl shadow-sm border border-gray-50">
                  <span class="bg-secondary/20 p-2 rounded-lg">✍️</span>
                  <span class="font-bold text-gray-700">Presentation skills for Board Exams</span>
                </div>
              </div>
              <a href={`${base}/contact`} class="inline-block bg-primary text-white px-8 py-3 rounded-xl font-black hover:bg-secondary hover:text-primary transition-all shadow-lg">
                Enquire Now
              </a>
            </div>
          </div>

          <!-- Economics -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="order-2 lg:order-1">
              <div class="inline-block bg-primary text-secondary px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest mb-4">Analytical Subject</div>
              <h2 class="text-3xl md:text-4xl font-black text-primary mb-6 uppercase">Economics</h2>
              <p class="text-gray-600 mb-8 leading-relaxed text-lg">
                From demand-supply curves to national income, we make economics relatable and easy to visualize.
              </p>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                <li class="flex items-center space-x-2 text-gray-700">
                  <span class="text-secondary">✔</span>
                  <span>Micro & Macro Economics</span>
                </li>
                <li class="flex items-center space-x-2 text-gray-700">
                  <span class="text-secondary">✔</span>
                  <span>Indian Economic Development</span>
                </li>
                <li class="flex items-center space-x-2 text-gray-700">
                  <span class="text-secondary">✔</span>
                  <span>Statistics for Economics</span>
                </li>
                <li class="flex items-center space-x-2 text-gray-700">
                  <span class="text-secondary">✔</span>
                  <span>Project Work Guidance</span>
                </li>
              </ul>
              <a href={`${base}/contact`} class="inline-block bg-secondary text-primary px-8 py-3 rounded-xl font-black hover:bg-primary hover:text-white transition-all shadow-lg">
                View Sample Notes
              </a>
            </div>
            <div class="order-1 lg:order-2 bg-primary/5 rounded-[3rem] p-12 flex items-center justify-center border border-primary/10">
              <span class="text-[10rem] md:text-[15rem] drop-shadow-2xl">📈</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Admission Banner -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4">
        <div class="bg-primary rounded-[2rem] p-12 text-center text-white shadow-2xl relative overflow-hidden">
          <div class="absolute top-0 right-0 p-8 text-secondary opacity-20 text-6xl rotate-12">📚</div>
          <h2 class="text-3xl font-black mb-4 uppercase tracking-tight">New Batch Starts 23rd March</h2>
          <p class="text-white/70 mb-8 italic">Don't miss the chance to start your session with Kota's best Commerce teaching!</p>
          <a href={`${base}/contact`} class="bg-secondary text-primary px-10 py-4 rounded-xl font-black text-lg hover:bg-white transition-all">
            Book Your Free Demo
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FloatingWhatsApp />
</Layout>
