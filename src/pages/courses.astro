---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="Courses" description="Explore our commerce curriculum for 11th and 12th standard. Expert-led coaching in Accountancy, Business Studies, and Economics in Kota.">
  <Navbar />
  
  <main class="dark:bg-[#0f1923] transition-colors duration-300">
    <!-- Page Header -->
    <section class="bg-primary text-white py-24 relative overflow-hidden dark:bg-[#0a1628] isolation-auto">
      <div class="absolute inset-0 opacity-10 z-[-1]">
        <div class="absolute top-0 right-0 w-64 h-64 bg-accent rounded-full filter blur-3xl z-[-1]"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10 space-y-4">
        <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Academic Excellence</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading uppercase tracking-tight">Our <span class="text-accent italic font-serif normal-case">Curriculum</span></h1>
        <div class="w-20 h-1 bg-accent mx-auto mt-6"></div>
        <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed pt-4">
          Structured learning programs designed to transform aspirants into board-exam achievers.
        </p>
      </div>
    </section>

    <!-- Course Breakdown -->
    <section class="section-padding bg-white dark:bg-[#0f1923] transition-colors duration-300 isolation-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-32">
          <!-- Accountancy Redesign -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="order-2 lg:order-1 space-y-8 animate-on-scroll">
              <div class="space-y-2">
                <p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px]">Core Mastery</p>
                <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight uppercase dark:text-white">Accountancy</h2>
              </div>
              <p class="text-text-gray text-lg leading-relaxed dark:text-gray-400">
                The cornerstone of commerce education. Our program simplifies complex accounting standards into intuitive logic, ensuring students master every entry and statement.
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                <div class="space-y-4">
                  <h4 class="font-bold text-primary font-heading border-b border-accent/20 pb-2 dark:text-white">Class 11th Focus</h4>    
                  <ul class="text-sm text-text-gray space-y-3 dark:text-gray-400">
                    <li class="flex items-center gap-2"><span class="text-accent">✦</span> Foundation Ledger systems</li>
                    <li class="flex items-center gap-2"><span class="text-accent">✦</span> Trial Balance Mastery</li>
                    <li class="flex items-center gap-2"><span class="text-accent">✦</span> Final Accounts Logic</li>
                  </ul>
                </div>
                <div class="space-y-4">
                  <h4 class="font-bold text-primary font-heading border-b border-accent/20 pb-2 dark:text-white">Class 12th Focus</h4>    
                  <ul class="text-sm text-text-gray space-y-3 dark:text-gray-400">
                    <li class="flex items-center gap-2"><span class="text-accent">✦</span> Partnership Complexities</li>
                    <li class="flex items-center gap-2"><span class="text-accent">✦</span> Corporate Shares Accounting</li>
                    <li class="flex items-center gap-2"><span class="text-accent">✦</span> Analytical Ratio Mastery</li>
                  </ul>
                </div>
              </div>
              <div class="pt-4">
                 <a href={`${base}/contact`} class="btn-gold inline-flex items-center gap-3">
                   Request Syllabus Details
                   <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                   </svg>
                 </a>
              </div>
            </div>
            <div class="order-1 lg:order-2 animate-on-scroll">
               <div class="aspect-square bg-bg-light rounded-[3rem] flex items-center justify-center relative overflow-hidden group dark:bg-[#1a2332] card">
                  <span class="text-[12rem] transition-transform duration-700 drop-shadow-2xl">📊</span>
                  <div class="absolute inset-0 border-[20px] border-white/50 rounded-[3rem] dark:border-white/5 z-[-1]"></div>
               </div>
            </div>
          </div>

          <!-- Business Studies Redesign -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="animate-on-scroll">
               <div class="aspect-square bg-accent/5 rounded-[3rem] flex items-center justify-center relative overflow-hidden group dark:bg-[#1a2332] card">
                  <span class="text-[12rem] transition-transform duration-700 drop-shadow-2xl">🏢</span>
                  <div class="absolute inset-0 border-[20px] border-white/50 rounded-[3rem] dark:border-white/5 z-[-1]"></div>
               </div>
            </div>
            <div class="space-y-8 animate-on-scroll">
              <div class="space-y-2">
                <p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px]">Strategic Management</p>
                <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight uppercase dark:text-white">Business Studies</h2>
              </div>
              <p class="text-text-gray text-lg leading-relaxed dark:text-gray-400">
                Beyond textbooks. We bridge the gap between theory and the corporate world through intensive case study analysis and mnemonic-based learning.
              </p>
              <div class="space-y-5">
                {[
                  { title: "Advanced Mnemonics", desc: "Memory techniques to retain complex points effortlessly." },
                  { title: "Case Study Lab", desc: "Weekly workshops decoding real-world business scenarios for exams." },
                  { title: "Presentation Excellence", desc: "Expert tips on answer writing to secure perfect 100/100." }
                ].map(item => (
                  <div class="flex items-start gap-4">
                    <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent text-[10px] flex-shrink-0 mt-1">✓</div>
                    <div>
                       <h5 class="font-bold text-primary text-sm dark:text-white">{item.title}</h5>
                       <p class="text-xs text-text-gray mt-1 dark:text-gray-400">{item.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
              <div class="pt-4">
                 <a href={`${base}/contact`} class="btn-gold">Enquire for Batch Timings</a>
              </div>
            </div>
          </div>

          <!-- Economics Redesign -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="order-2 lg:order-1 space-y-8 animate-on-scroll">
              <div class="space-y-2">
                <p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px]">Analytical Insights</p>
                <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight uppercase dark:text-white">Economics</h2>
              </div>
              <p class="text-text-gray text-lg leading-relaxed dark:text-gray-400">
                Mastering the graph and the logic. We simplify complex economic models into visual insights, ensuring high-retention learning.
              </p>
              <div class="grid grid-cols-2 gap-4">
                 <div class="p-6 bg-bg-light rounded-2xl border border-gray-100 dark:bg-[#1a2332] dark:border-gray-800 card">
                    <p class="text-2xl mb-2">📈</p>
                    <p class="text-xs font-bold text-primary dark:text-white">Micro & Macro Focus</p>
                 </div>
                 <div class="p-6 bg-bg-light rounded-2xl border border-gray-100 dark:bg-[#1a2332] dark:border-gray-800 card">
                    <p class="text-2xl mb-2">🌍</p>
                    <p class="text-xs font-bold text-primary dark:text-white">Indian Economy Analysis</p>
                 </div>
                 <div class="p-6 bg-bg-light rounded-2xl border border-gray-100 dark:bg-[#1a2332] dark:border-gray-800 card">
                    <p class="text-2xl mb-2">📊</p>
                    <p class="text-xs font-bold text-primary dark:text-white">Graphical Mastery</p>
                 </div>
                 <div class="p-6 bg-bg-light rounded-2xl border border-gray-100 dark:bg-[#1a2332] dark:border-gray-800 card">
                    <p class="text-2xl mb-2">✍️</p>
                    <p class="text-xs font-bold text-primary dark:text-white">Project Guidance</p>
                 </div>
              </div>
              <div class="pt-4">
                 <a href={`${base}/contact`} class="btn-gold">View Sample Study Material</a>
              </div>
            </div>
            <div class="order-1 lg:order-2 animate-on-scroll">
               <div class="aspect-square bg-primary/5 rounded-[3rem] flex items-center justify-center relative overflow-hidden group dark:bg-[#1a2332] card">
                  <span class="text-[12rem] transition-transform duration-700 drop-shadow-2xl">📈</span>
                  <div class="absolute inset-0 border-[20px] border-white/50 rounded-[3rem] dark:border-white/5 z-[-1]"></div>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="section-padding bg-bg-light dark:bg-[#0f1923] transition-colors duration-300 isolation-auto">
      <div class="max-w-4xl mx-auto px-4">
        <div class="bg-primary rounded-[3rem] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl dark:bg-[#0a1628] dark:shadow-none dark:border dark:border-gray-800 animate-on-scroll isolation-auto">
          <div class="absolute top-0 right-0 p-12 text-accent/10 text-9xl rotate-12 z-[-1]">💎</div>
          <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs mb-6">Join Us</p>
          <h2 class="text-3xl md:text-4xl font-bold font-heading mb-8 uppercase tracking-tight">New Batch Begins <br /><span class="text-accent">23rd March 2026</span></h2>
          <p class="text-white/50 mb-12 max-w-xl mx-auto italic">"The best time to start your journey to success is now. Secure your seat in Kota's trusted commerce institute."</p>
          <a href={`${base}/contact`} class="btn-gold px-12 py-5 text-lg">
            Book Free Demo Now
          </a>
        </div>
      </div>
    </section>
    </main>
  
  <Footer />
</Layout>
