---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="Contact Us" description="Get in touch with Uma Commerce Classes in Kota. Call us at 9351595412 or visit our institute at Uma Grah, New Post Office Road.">
  <Navbar />
  
  <main>
    <!-- Page Header -->
    <section class="bg-primary text-white py-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-secondary rounded-full filter blur-3xl"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
        <h1 class="text-4xl md:text-6xl font-black mb-6 uppercase tracking-tight">Contact <span class="text-secondary">Us</span></h1>
        <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed">
          Have questions? We're here to help you start your journey towards academic excellence.
        </p>
      </div>
    </section>

    <!-- Contact Details & Form -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <!-- Contact Info -->
          <div>
            <h2 class="text-3xl font-black text-primary mb-8 uppercase tracking-tight">Get In Touch</h2>
            <div class="space-y-10">
              <div class="flex items-start space-x-6">
                <div class="w-14 h-14 bg-secondary/20 rounded-2xl flex items-center justify-center flex-shrink-0 text-2xl">📍</div>
                <div>
                  <h4 class="text-xl font-bold text-primary mb-2">Our Location</h4>
                  <p class="text-gray-600 leading-relaxed">
                    Uma Grah, New Post Office Road,<br />
                    Kota, Rajasthan - 324001
                  </p>
                  <a href="#" class="text-primary font-bold text-sm mt-2 inline-block border-b-2 border-secondary">Get Directions on Maps</a>
                </div>
              </div>
              
              <div class="flex items-start space-x-6">
                <div class="w-14 h-14 bg-secondary/20 rounded-2xl flex items-center justify-center flex-shrink-0 text-2xl">📞</div>
                <div>
                  <h4 class="text-xl font-bold text-primary mb-2">Call or WhatsApp</h4>
                  <p class="text-gray-600 mb-1">+91 93515 95412</p>
                  <p class="text-gray-600">+91 94144 54052</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-6">
                <div class="w-14 h-14 bg-secondary/20 rounded-2xl flex items-center justify-center flex-shrink-0 text-2xl">✉️</div>
                <div>
                  <h4 class="text-xl font-bold text-primary mb-2">Email Address</h4>
                  <p class="text-gray-600">info@umacommerceclasses.com</p>
                  <p class="text-gray-600">anuja.mittal@gmail.com</p>
                </div>
              </div>

              <!-- Quick CTA -->
              <div class="bg-primary text-white p-8 rounded-[2rem] shadow-2xl relative overflow-hidden">
                <div class="relative z-10">
                  <h3 class="text-xl font-black text-secondary mb-2 uppercase">Free 5-Day Demo</h3>
                  <p class="text-white/70 text-sm mb-6">Experience our teaching quality before you enroll. No strings attached!</p>
                  <a href="https://wa.me/919351595412" class="inline-block bg-white text-primary px-6 py-2 rounded-lg font-bold hover:bg-secondary transition-colors">Chat on WhatsApp</a>
                </div>
                <div class="absolute -right-4 -bottom-4 text-white/5 text-8xl font-black rotate-12">FREE</div>
              </div>
            </div>
          </div>

          <!-- Inquiry Form -->
          <div class="bg-gray-50 p-10 rounded-[3rem] border border-gray-100 shadow-xl">
            <h3 class="text-2xl font-black text-primary mb-8 text-center uppercase">Send an Inquiry</h3>
            <form class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Student Name</label>
                  <input type="text" placeholder="Full Name" class="w-full px-4 py-4 rounded-xl bg-white border border-gray-200 focus:border-secondary outline-none transition-all shadow-sm" />
                </div>
                <div>
                  <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Phone Number</label>
                  <input type="tel" placeholder="10-digit number" class="w-full px-4 py-4 rounded-xl bg-white border border-gray-200 focus:border-secondary outline-none transition-all shadow-sm" />
                </div>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Select Class</label>
                <select class="w-full px-4 py-4 rounded-xl bg-white border border-gray-200 focus:border-secondary outline-none transition-all shadow-sm">
                  <option>Class 11th Commerce</option>
                  <option>Class 12th Commerce</option>
                  <option>Other / General Inquiry</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Your Message</label>
                <textarea rows="4" placeholder="Tell us which subjects you're interested in..." class="w-full px-4 py-4 rounded-xl bg-white border border-gray-200 focus:border-secondary outline-none transition-all shadow-sm resize-none"></textarea>
              </div>
              <button type="submit" class="w-full bg-primary text-white py-5 rounded-xl font-black text-lg hover:bg-primary-dark transition-all shadow-xl uppercase tracking-wider">
                Send Inquiry Now
              </button>
            </form>
            <p class="text-center text-gray-400 text-xs mt-6 italic">We usually respond within 2-4 business hours.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Placeholder -->
    <section class="pb-24 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto h-[450px] bg-gray-100 rounded-[3rem] border-4 border-white shadow-2xl overflow-hidden relative flex items-center justify-center group">
        <div class="text-center p-12 relative z-10">
          <div class="text-6xl mb-6 group-hover:scale-110 transition-transform">📍</div>
          <h3 class="text-2xl font-black text-primary mb-2 uppercase">Our Institute Location</h3>
          <p class="text-gray-500 italic">Uma Grah, New Post Office Road, Kota, Rajasthan</p>
          <div class="mt-8">
            <span class="bg-primary text-white px-8 py-3 rounded-full font-bold text-sm shadow-lg">Google Maps Integration Area</span>
          </div>
        </div>
        <div class="absolute inset-0 bg-primary/5"></div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FloatingWhatsApp />
</Layout>
