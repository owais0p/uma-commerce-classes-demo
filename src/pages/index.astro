---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import CourseCard from '../components/CourseCard.astro';
import TopperCard from '../components/TopperCard.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="Home">
	<Navbar />
	
	<main>
		<!-- Hero Section -->
		<section class="relative bg-primary text-white py-20 lg:py-32 overflow-hidden">
			<div class="absolute inset-0 opacity-10">
				<div class="absolute top-0 left-0 w-96 h-96 bg-secondary rounded-full filter blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
				<div class="absolute bottom-0 right-0 w-96 h-96 bg-secondary rounded-full filter blur-3xl translate-x-1/2 translate-y-1/2"></div>
			</div>
			
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div class="space-y-8 text-center lg:text-left">
						<div class="inline-block bg-secondary text-primary px-4 py-1.5 rounded-full text-sm font-black uppercase tracking-widest animate-bounce">
							Admission Open: New Batch 23rd March 2026
						</div>
						<h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-tight tracking-tight">
							Marks Nahi... <br />
							<span class="text-secondary">TOPPER</span> Banna Hai?
						</h1>
						<p class="text-xl text-white/80 max-w-2xl mx-auto lg:mx-0 leading-relaxed font-medium">
							Join Kota's leading commerce institute for Accountancy, Business Studies & Economics. Excellence is not an act, but a habit here.
						</p>
						<div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4">
							<a href={`${base}/contact`} class="bg-secondary text-primary px-10 py-4 rounded-xl font-black text-lg hover:bg-white transition-all shadow-2xl transform hover:-translate-y-1">
								Get Free 5-Day Demo
							</a>
							<a href="#courses" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-10 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition-all">
								View Courses
							</a>
						</div>
						<div class="flex items-center justify-center lg:justify-start space-x-6 pt-4 text-sm text-white/60">
							<div class="flex items-center"><span class="text-secondary mr-2">⭐</span> AC Classrooms</div>
							<div class="flex items-center"><span class="text-secondary mr-2">⭐</span> Small Batches</div>
							<div class="flex items-center"><span class="text-secondary mr-2">⭐</span> Weekly Tests</div>
						</div>
					</div>
					
					<!-- Enrollment Form Mini -->
					<div class="bg-white rounded-3xl p-8 text-gray-900 shadow-2xl border border-white/20 max-w-md mx-auto lg:ml-auto w-full">
						<h2 class="text-2xl font-bold mb-6 text-primary border-b border-gray-100 pb-4 text-center lg:text-left">Book Your Seat Now</h2>
						<form class="space-y-4">
							<div>
								<label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1 ml-1">Student Name</label>
								<input type="text" placeholder="Enter Full Name" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all" />
							</div>
							<div>
								<label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1 ml-1">Phone Number</label>
								<input type="tel" placeholder="+91 XXXXX XXXXX" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all" />
							</div>
							<div>
								<label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1 ml-1">Class</label>
								<select class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:border-secondary outline-none">
									<option>11th Commerce</option>
									<option>12th Commerce</option>
								</select>
							</div>
							<button type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-bold text-lg hover:bg-primary-dark transition-all mt-4 shadow-xl">
								Enquire for Demo Class
							</button>
						</form>
						<p class="text-[10px] text-center text-gray-400 mt-4 italic">No credit card required. Experience 5 days of quality teaching for free.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Dainik Bhaskar News Strip -->
		<section class="bg-secondary/10 py-6 border-y border-secondary/20">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-12">
				<div class="flex items-center space-x-3">
					<span class="bg-primary text-secondary px-3 py-1 font-black rounded italic text-lg">DB</span>
					<span class="font-bold text-primary">Dainik Bhaskar Featured</span>
				</div>
				<div class="h-8 w-px bg-secondary/30 hidden md:block"></div>
				<p class="text-primary/80 font-medium text-center md:text-left">
					"15+ students scored 90%+ marks in Board Exams 2024" — Uma Commerce Classes in spotlight!
				</p>
			</div>
		</section>

		<!-- Stats Section -->
		<section class="py-20 bg-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
					<div class="text-center group">
						<div class="text-4xl md:text-5xl font-black text-primary mb-2 group-hover:text-secondary transition-colors">15+</div>
						<div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Students with 90%+</div>
					</div>
					<div class="text-center group">
						<div class="text-4xl md:text-5xl font-black text-primary mb-2 group-hover:text-secondary transition-colors">99/100</div>
						<div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Top Score in Accounts</div>
					</div>
					<div class="text-center group">
						<div class="text-4xl md:text-5xl font-black text-primary mb-2 group-hover:text-secondary transition-colors">5 Days</div>
						<div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Free Demo Class</div>
					</div>
					<div class="text-center group">
						<div class="text-4xl md:text-5xl font-black text-primary mb-2 group-hover:text-secondary transition-colors">AC</div>
						<div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Hi-Tech Classrooms</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Star Result Section -->
		<section class="py-20 bg-gray-50 relative overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-4xl font-black text-primary mb-4 tracking-tight uppercase">Our Shining Star</h2>
					<p class="text-gray-600 max-w-2xl mx-auto">Success is the result of preparation, hard work, and learning from failure.</p>
				</div>
				
				<div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border border-secondary/20 flex flex-col md:flex-row">
					<div class="md:w-2/5 bg-primary flex items-center justify-center p-12 text-white">
						<div class="text-center">
							<div class="w-32 h-32 md:w-48 md:h-48 rounded-full border-4 border-secondary mx-auto mb-6 flex items-center justify-center bg-white/10 text-6xl">
								🏆
							</div>
							<h3 class="text-3xl font-black text-secondary">99/100</h3>
							<p class="text-sm uppercase tracking-widest font-bold opacity-70">Accountancy</p>
						</div>
					</div>
					<div class="md:w-3/5 p-12 flex flex-col justify-center">
						<div class="text-secondary text-5xl mb-6">“</div>
						<p class="text-2xl font-serif text-primary italic mb-8 leading-relaxed">
							Uma Ma'am's guidance and the rigorous weekly tests at Uma Commerce Classes helped me achieve this incredible score in 12th CBSE Board!
						</p>
						<div>
							<h4 class="text-2xl font-black text-primary">Ravneet Singh Makhija</h4>
							<p class="text-gray-500 font-bold uppercase tracking-widest text-sm">12th CBSE Board 2024</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Subjects Section -->
		<section id="courses" class="py-24 bg-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-black text-primary mb-4 tracking-tight uppercase">Subjects We Teach</h2>
					<div class="w-24 h-1.5 bg-secondary mx-auto rounded-full"></div>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<CourseCard 
						title="Accountancy"
						classes="Class 11 & 12 (CBSE/RBSE)"
						description="Master the world of numbers and financial statements with conceptual clarity."
						features={["Conceptual Mastery", "Sample Paper Solving", "Practical Approach"]}
						icon="📊"
					/>
					<CourseCard 
						title="Business Studies"
						classes="Class 11 & 12 (CBSE/RBSE)"
						description="Learn management principles and business environment with real-life case studies."
						features={["Case Study Analysis", "Memory Techniques", "Answer Writing Focus"]}
						icon="🏢"
					/>
					<CourseCard 
						title="Economics"
						classes="Class 11 & 12 (CBSE/RBSE)"
						description="Understand micro and macro economics with easy-to-grasp graphical explanations."
						features={["Graphical Explanations", "Current Affairs Integration", "Note Making Skills"]}
						icon="📈"
					/>
				</div>
			</div>
		</section>

		<!-- Why Choose Us -->
		<section class="py-24 bg-primary text-white">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
					<div>
						<h2 class="text-3xl md:text-5xl font-black mb-8 tracking-tight uppercase leading-tight">
							Why <span class="text-secondary">Uma Commerce</span> <br />is Your Best Choice?
						</h2>
						<div class="space-y-6">
							<div class="flex items-start space-x-4">
								<div class="w-12 h-12 rounded-2xl bg-secondary/20 flex items-center justify-center flex-shrink-0 border border-secondary/30">
									<span class="text-2xl">👨‍🏫</span>
								</div>
								<div>
									<h4 class="text-xl font-bold text-secondary mb-1">Smart Teaching Methodology</h4>
									<p class="text-white/70">Using modern tools and techniques to make complex commerce concepts easy to understand.</p>
								</div>
							</div>
							<div class="flex items-start space-x-4">
								<div class="w-12 h-12 rounded-2xl bg-secondary/20 flex items-center justify-center flex-shrink-0 border border-secondary/30">
									<span class="text-2xl">👥</span>
								</div>
								<div>
									<h4 class="text-xl font-bold text-secondary mb-1">Small Batches</h4>
									<p class="text-white/70">Personal attention to every student. We don't run factories, we nurture individuals.</p>
								</div>
							</div>
							<div class="flex items-start space-x-4">
								<div class="w-12 h-12 rounded-2xl bg-secondary/20 flex items-center justify-center flex-shrink-0 border border-secondary/30">
									<span class="text-2xl">📝</span>
								</div>
								<div>
									<h4 class="text-xl font-bold text-secondary mb-1">Weekly Tests & Result Analysis</h4>
									<p class="text-white/70">Regular assessment with detailed feedback to track and improve student performance.</p>
								</div>
							</div>
							<div class="flex items-start space-x-4">
								<div class="w-12 h-12 rounded-2xl bg-secondary/20 flex items-center justify-center flex-shrink-0 border border-secondary/30">
									<span class="text-2xl">💡</span>
								</div>
								<div>
									<h4 class="text-xl font-bold text-secondary mb-1">Doubt Solving Sessions</h4>
									<p class="text-white/70">Dedicated time for solving individual student doubts to ensure no one is left behind.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="relative">
						<div class="aspect-square bg-white/5 rounded-[3rem] border border-white/10 flex items-center justify-center overflow-hidden">
							<div class="text-center p-12">
								<div class="text-8xl mb-8">🏫</div>
								<h3 class="text-3xl font-black text-secondary mb-4 uppercase">Hi-Tech AC Classrooms</h3>
								<p class="text-white/60 leading-relaxed italic">
									"Learning is most effective when the environment is comfortable and technology-driven."
								</p>
							</div>
						</div>
						<div class="absolute -bottom-8 -right-8 bg-secondary text-primary p-8 rounded-3xl shadow-2xl hidden md:block max-w-xs transform rotate-3 hover:rotate-0 transition-transform">
							<p class="font-black text-2xl uppercase leading-tight mb-2">Board Exam Focus</p>
							<p class="text-sm font-bold opacity-80">Rigorous practice with previous 10 years papers.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Banner -->
		<section class="py-12 bg-secondary">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<h2 class="text-2xl md:text-3xl font-black text-primary uppercase tracking-tight mb-6">Start Your Journey to 100/100 Today!</h2>
				<div class="flex flex-col md:flex-row justify-center items-center gap-6">
					<a href={`${base}/contact`} class="bg-primary text-white px-12 py-4 rounded-xl font-black text-lg hover:bg-primary-dark transition-all shadow-xl w-full md:w-auto">
						Claim Your 5-Day Free Demo
					</a>
					<div class="flex items-center space-x-3 text-primary font-bold">
						<span>Call Now:</span>
						<a href="tel:+919351595412" class="text-2xl underline decoration-2 underline-offset-4">93515 95412</a>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<FloatingWhatsApp />
</Layout>
