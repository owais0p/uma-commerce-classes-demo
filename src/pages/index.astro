---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import CourseCard from '../components/CourseCard.astro';
import TopperCard from '../components/TopperCard.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="Home">
	<Navbar />
	
	<main>
		<!-- Hero Section Redesign -->
		<section class="relative min-h-[85vh] flex items-center bg-white overflow-hidden pt-12">
			<!-- Subtle Navy Background Decorative Element -->
			<div class="absolute top-0 right-0 w-1/3 h-full bg-primary/5 -skew-x-12 translate-x-1/2"></div>
			
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
				<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
					<div class="lg:col-span-7 space-y-8 text-center lg:text-left">
						<div class="inline-flex items-center space-x-2 bg-bg-light border border-gray-100 px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-[0.2em] text-accent animate-fade-in">
							<span class="flex h-2 w-2 rounded-full bg-accent animate-pulse"></span>
							<span>Admission Open: Batch 23rd March 2026</span>
						</div>
						<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-primary font-heading tracking-tight max-w-2xl mx-auto lg:mx-0">
							Marks Nahi... <br />
							<span class="text-accent italic font-serif">TOPPER</span> Banna Hai?
						</h1>
						<p class="text-lg text-text-gray max-w-xl mx-auto lg:mx-0 leading-relaxed">
							Redefining commerce education in Kota with premium coaching, elite faculty, and a tradition of 100/100 scores.
						</p>
						<div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-5 pt-4">
							<a href={`${base}/contact`} class="btn-gold px-12 py-4 text-lg shadow-xl shadow-accent/20">
								Start 5-Day Free Demo
							</a>
							<a href="#courses" class="px-12 py-4 text-lg font-bold text-primary hover:text-accent transition-colors flex items-center justify-center gap-2 group border border-gray-100 rounded-lg hover:border-accent">
								Explore Courses
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>
						
						<!-- Elite Stats -->
						<div class="grid grid-cols-3 gap-8 pt-12 border-t border-gray-100 max-w-lg mx-auto lg:mx-0">
							<div>
								<p class="text-2xl font-bold text-primary font-heading">15+</p>
								<p class="text-[10px] text-text-gray uppercase tracking-widest font-bold">90%+ Scores</p>
							</div>
							<div>
								<p class="text-2xl font-bold text-primary font-heading">99/100</p>
								<p class="text-[10px] text-text-gray uppercase tracking-widest font-bold">Top Accounts</p>
							</div>
							<div>
								<p class="text-2xl font-bold text-primary font-heading">Elite</p>
								<p class="text-[10px] text-text-gray uppercase tracking-widest font-bold">Faculty</p>
							</div>
						</div>
					</div>
					
					<!-- Premium Form Card -->
					<div class="lg:col-span-5 relative">
						<div class="bg-white rounded-2xl p-10 shadow-2xl shadow-primary/5 border border-gray-50 relative z-10">
							<h3 class="text-2xl font-bold text-primary mb-2 font-heading">Enquire Now</h3>
							<p class="text-sm text-text-gray mb-8">Begin your journey to excellence today.</p>
							
							<form class="space-y-5">
								<div class="space-y-1.5">
									<label class="text-[10px] font-bold text-text-gray uppercase tracking-widest ml-1">Full Name</label>
									<input type="text" placeholder="e.g., Ravneet Singh" class="w-full px-5 py-4 rounded-lg bg-bg-light border border-gray-100 focus:border-accent focus:bg-white focus:ring-4 focus:ring-accent/5 outline-none transition-all text-sm" />
								</div>
								<div class="space-y-1.5">
									<label class="text-[10px] font-bold text-text-gray uppercase tracking-widest ml-1">Phone Number</label>
									<input type="tel" placeholder="+91 XXXXX XXXXX" class="w-full px-5 py-4 rounded-lg bg-bg-light border border-gray-100 focus:border-accent focus:bg-white focus:ring-4 focus:ring-accent/5 outline-none transition-all text-sm" />
								</div>
								<div class="space-y-1.5">
									<label class="text-[10px] font-bold text-text-gray uppercase tracking-widest ml-1">Target Class</label>
									<select class="w-full px-5 py-4 rounded-lg bg-bg-light border border-gray-100 focus:border-accent focus:bg-white focus:ring-4 focus:ring-accent/5 outline-none transition-all text-sm appearance-none cursor-pointer">
										<option>11th Commerce</option>
										<option>12th Commerce</option>
									</select>
								</div>
								<button type="submit" class="w-full btn-gold py-5 text-lg shadow-xl shadow-accent/20 mt-4 uppercase tracking-widest font-bold">
									Confirm Free Demo
								</button>
							</form>
						</div>
						<!-- Decorative backdrop for form -->
						<div class="absolute -bottom-6 -right-6 w-full h-full bg-bg-light rounded-2xl -z-0"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Trust Strip -->
		<section class="bg-primary text-white py-12">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between space-y-8 md:space-y-0 text-center md:text-left">
				<div class="space-y-1">
					<p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px]">Media Recognition</p>
					<h4 class="text-xl font-heading">As Featured in <span class="italic">Dainik Bhaskar</span></h4>
				</div>
				<div class="h-12 w-px bg-white/10 hidden md:block"></div>
				<p class="text-white/60 text-sm max-w-md leading-relaxed italic">
					"A landmark of commerce results in Kota — Uma Commerce Classes consistently delivers 90%+ achievers year after year."
				</p>
				<div class="flex items-center space-x-2 bg-white/5 px-6 py-3 rounded-full border border-white/10">
					<span class="text-accent text-xl font-bold">15+</span>
					<span class="text-[10px] font-bold uppercase tracking-widest text-white/70">Top Rankers 2024</span>
				</div>
			</div>
		</section>

		<!-- Features Redesign -->
		<section class="section-padding bg-bg-light">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16 space-y-3">
					<p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">The Uma Edge</p>
					<h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight">Why Choose Elite Coaching?</h2>
					<div class="w-20 h-1 bg-accent mx-auto"></div>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
					{[
						{ title: "Elite Faculty", desc: "Led by Anuja Mittal Ma'am with decades of proven success.", icon: "👨‍🏫" },
						{ title: "Small Batches", desc: "Ultra-personalized attention for every future topper.", icon: "👥" },
						{ title: "Smart Hybrid", desc: "Modern teaching tools for deeper conceptual clarity.", icon: "💻" },
						{ title: "AC Elite Class", desc: "Premium environment designed for focused learning.", icon: "❄️" }
					].map(feature => (
						<div class="bg-white p-8 rounded-xl shadow-sm hover:shadow-xl transition-all border border-gray-100 group">
							<div class="text-4xl mb-6 group-hover:scale-110 transition-transform duration-300 inline-block">{feature.icon}</div>
							<h4 class="text-lg font-bold text-primary mb-3 font-heading">{feature.title}</h4>
							<p class="text-sm text-text-gray leading-relaxed">{feature.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Star Student Spotlight Redesign -->
		<section class="section-padding bg-white relative overflow-hidden">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
				<div class="bg-primary rounded-[2rem] p-12 lg:p-20 text-white shadow-2xl relative overflow-hidden">
					<div class="absolute top-0 right-0 w-1/2 h-full bg-accent/5 -skew-x-12 translate-x-1/2"></div>
					
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
						<div class="space-y-8 order-2 lg:order-1">
							<div class="inline-block bg-accent/20 border border-accent/30 text-accent px-4 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-widest">
								Star Result 2024
							</div>
							<h2 class="text-3xl md:text-4xl font-bold font-heading leading-tight tracking-tight">
								"My 99/100 in Accountancy is a <br />Testament to Uma Ma'am's Expertise."
							</h2>
							<div class="space-y-2">
								<p class="text-xl font-bold font-heading text-accent">Ravneet Singh Makhija</p>
								<p class="text-sm text-white/60 uppercase tracking-widest font-bold">12th CBSE Board • Accountancy Top Scorer</p>
							</div>
							<p class="text-white/70 leading-relaxed italic border-l-2 border-accent pl-6 py-2">
								"The weekly tests and personalized doubt sessions were the keys to my success. At Uma Commerce Classes, we don't just study, we master the subject."
							</p>
						</div>
						
						<div class="order-1 lg:order-2 flex justify-center">
							<div class="relative w-full max-w-sm aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl ring-8 ring-white/5">
								<img src={`${base}/images/toppers/Screenshot 2026-05-31 003101.png`} alt="Ravneet Singh" class="w-full h-full object-cover" />
								<div class="absolute inset-0 bg-gradient-to-t from-primary via-transparent to-transparent opacity-60"></div>
								<div class="absolute bottom-6 left-6 text-white">
									<p class="text-4xl font-bold font-heading">99/100</p>
									<p class="text-[10px] font-bold uppercase tracking-widest text-accent">Certified Result</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Courses Quick Preview -->
		<section id="courses" class="section-padding bg-bg-light">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
					<div class="space-y-3 text-center md:text-left">
						<p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Premium Programs</p>
						<h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight">Elite Commerce Stream</h2>
					</div>
					<a href={`${base}/courses`} class="text-primary font-bold border-b-2 border-accent pb-1 hover:text-accent transition-colors uppercase tracking-widest text-xs">View All Courses</a>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<CourseCard 
						title="Accountancy"
						classes="Elite Class 11 & 12"
						description="Master numerical mastery with conceptual foundations and elite practice."
						features={["Conceptual Mastery", "Sample Paper Elite", "Practical Approach"]}
						icon="📊"
					/>
					<CourseCard 
						title="Business Studies"
						classes="Elite Class 11 & 12"
						description="Strategic management principles explored through elite case studies."
						features={["Case Study Analysis", "Memory Mnemonics", "Answer Writing Focus"]}
						icon="🏢"
					/>
					<CourseCard 
						title="Economics"
						classes="Elite Class 11 & 12"
						description="Analytical understanding of global and local economic principles."
						features={["Graphical Elite", "Current Affairs", "Note Mastery"]}
						icon="📈"
					/>
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section class="py-20 bg-white">
			<div class="max-w-5xl mx-auto px-4 text-center">
				<div class="bg-accent/5 rounded-[3rem] p-12 md:p-20 border border-accent/10">
					<h2 class="text-3xl md:text-4xl font-bold text-primary font-heading mb-6">Elevate Your Academic Performance</h2>
					<p class="text-text-gray mb-10 max-w-2xl mx-auto text-lg leading-relaxed">
						Limited seats available for the 2026-27 session. Experience the premium coaching that has transformed hundreds of students into toppers.
					</p>
					<div class="flex flex-col sm:flex-row justify-center gap-4">
						<a href={`${base}/contact`} class="btn-gold px-12 py-5 text-lg shadow-xl shadow-accent/20">
							Book Elite Demo Class
						</a>
						<a href="tel:+919351595412" class="px-12 py-5 font-bold text-primary hover:text-accent transition-colors flex items-center justify-center gap-3 bg-white border border-gray-100 rounded-lg">
							<span class="text-xl">📞</span> 93515 95412
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<FloatingWhatsApp />
</Layout>

<style>
	.animate-fade-in {
		animation: fadeIn 1s ease-out;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
