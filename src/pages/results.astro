---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import TopperCard from '../components/TopperCard.astro';

const base = '/uma-commerce-classes-demo';
---

<Layout title="Results" description="Celebrating the success of our toppers. See the outstanding board exam results from Uma Commerce Classes, Kota.">
  <Navbar />
  
  <main>
    <!-- Page Header -->
    <section class="bg-primary text-white py-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-48 h-48 bg-secondary rounded-full filter blur-3xl"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
        <h1 class="text-4xl md:text-6xl font-black mb-6 uppercase tracking-tight">Our <span class="text-secondary">Toppers</span></h1>
        <p class="text-xl text-white/70 max-w-3xl mx-auto leading-relaxed">
          Celebrating the hard work and dedication of our brilliant students who made us proud in the board exams.
        </p>
      </div>
    </section>

    <!-- Star Result Spotlight -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-secondary text-5xl mb-4 block">🏆</span>
          <h2 class="text-3xl md:text-5xl font-black text-primary mb-4 uppercase tracking-tight">The 99% Achievement</h2>
          <div class="w-24 h-1.5 bg-secondary mx-auto rounded-full"></div>
        </div>

        <div class="max-w-5xl mx-auto">
          <TopperCard 
            name="Ravneet Singh Makhija"
            score="99/100"
            subject="Accountancy"
            year="2024"
            isStar={true}
          />
        </div>
      </div>
    </section>

    <!-- News Feature Section -->
    <section class="py-20 bg-primary text-white overflow-hidden relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-block bg-secondary text-primary px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest mb-6">Media Recognition</div>
            <h2 class="text-3xl md:text-5xl font-black mb-8 leading-tight">Featured in <span class="text-secondary italic">Dainik Bhaskar</span></h2>
            <p class="text-white/70 text-lg mb-8 leading-relaxed italic">
              "Uma Commerce Classes has once again proven its excellence in commerce education with 15+ students scoring above 90% in the latest board examinations."
            </p>
            <div class="flex items-center space-x-6">
              <div class="flex -space-x-4">
                {[1, 2, 3, 4].map((i) => (
                  <div class="w-12 h-12 rounded-full border-2 border-primary bg-secondary/20 flex items-center justify-center text-primary font-bold">
                    {i}
                  </div>
                ))}
                <div class="w-12 h-12 rounded-full border-2 border-primary bg-white text-primary flex items-center justify-center text-xs font-black">
                  +11
                </div>
              </div>
              <span class="font-bold text-secondary">15+ Students with 90%+</span>
            </div>
          </div>
          <div class="relative">
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 p-12 rounded-[3rem] shadow-2xl rotate-2">
              <div class="text-center">
                <p class="text-6xl mb-6">📰</p>
                <h3 class="text-2xl font-black text-secondary mb-4 uppercase">Headline: Kota's Excellence</h3>
                <p class="text-white/60 text-sm leading-relaxed">
                  The results speak for themselves. With dedicated faculty and focused teaching, Uma Commerce Classes continues to lead the way in Kota's commerce coaching circuit.
                </p>
              </div>
            </div>
            <!-- Decorative dots -->
            <div class="absolute -top-6 -right-6 grid grid-cols-3 gap-2 opacity-20">
              {[...Array(9)].map(() => <div class="w-2 h-2 bg-secondary rounded-full"></div>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Results Grid -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-black text-primary mb-4 uppercase tracking-tight">Wall of Fame</h2>
          <p class="text-gray-500">More students who made us proud with their consistent hard work.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <TopperCard name="Student Name" score="96/100" subject="Accountancy" year="2024" />
          <TopperCard name="Student Name" score="95/100" subject="Economics" year="2024" />
          <TopperCard name="Student Name" score="94/100" subject="Business Studies" year="2024" />
          <TopperCard name="Student Name" score="92/100" subject="Accountancy" year="2024" />
          <TopperCard name="Student Name" score="91/100" subject="Economics" year="2024" />
          <TopperCard name="Student Name" score="90/100" subject="Business Studies" year="2024" />
        </div>
        
        <div class="mt-16 text-center">
          <p class="text-gray-400 italic mb-8">...and many more who achieved distinction scores!</p>
          <a href={`${base}/contact`} class="bg-primary text-white px-10 py-4 rounded-xl font-black hover:bg-secondary hover:text-primary transition-all shadow-xl inline-block">
            Start Your Success Story
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FloatingWhatsApp />
</Layout>
