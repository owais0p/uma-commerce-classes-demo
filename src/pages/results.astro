---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import TopperCard from '../components/TopperCard.astro';

const base = '/uma-commerce-classes-demo';

const toppers = [
  { name: "Ravneet Singh Makhija", score: "99/100", subject: "Accountancy", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003101.png`, isStar: true },
  { name: "Aditya Sharma", score: "96/100", subject: "Accountancy", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003119.png` },
  { name: "Priya Verma", score: "95/100", subject: "Economics", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003134.png` },
  { name: "Kunal Gupta", score: "94/100", subject: "Business Studies", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003147.png` },
  { name: "Sneha Jain", score: "92/100", subject: "Accountancy", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003158.png` },
  { name: "Rohan Malhotra", score: "91/100", subject: "Economics", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003210.png` },
  { name: "Ananya Singh", score: "90/100", subject: "Business Studies", year: "2024", image: `${base}/images/toppers/Screenshot 2026-05-31 003222.png` },
];
---

<Layout title="Elite Results" description="Celebrating the success of our elite toppers. Explore the outstanding board exam results from Uma Commerce Classes, Kota.">
  <Navbar />
  
  <main>
    <!-- Page Header -->
    <section class="bg-primary text-white py-24 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-48 h-48 bg-accent rounded-full filter blur-3xl"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10 space-y-4">
        <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Hall of Fame</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading uppercase tracking-tight">Elite <span class="text-accent italic font-serif normal-case">Results</span> 2024</h1>
        <div class="w-20 h-1 bg-accent mx-auto mt-6"></div>
        <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed pt-4">
          Witness the excellence of students who mastered the commerce curriculum under elite guidance.
        </p>
      </div>
    </section>

    <!-- Star Result Spotlight Redesign -->
    <section class="section-padding bg-bg-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <TopperCard {...toppers[0]} />
          
          <div class="mt-12 bg-white p-10 rounded-2xl shadow-xl border border-gray-100 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-8 text-accent/10 text-8xl">📰</div>
            <div class="relative z-10">
               <p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px] mb-2">Media Recognition</p>
               <h3 class="text-2xl font-bold text-primary font-heading mb-4">"A Record-Breaking Year in Kota"</h3>
               <p class="text-text-gray leading-relaxed text-lg italic border-l-4 border-accent pl-6">
                 "Uma Commerce Classes has once again set the gold standard in coaching. With 15+ students securing 90%+ marks, the institute continues to be the first choice for serious commerce aspirants."
                 <br />
                 <span class="block mt-4 text-sm font-bold text-primary">— Dainik Bhaskar Bureau</span>
               </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Wall of Fame Grid -->
    <section class="section-padding bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 space-y-3">
          <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Consistent Excellence</p>
          <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight">Elite Rankers Gallery</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {toppers.slice(1).map(topper => (
            <TopperCard {...topper} />
          ))}
        </div>
        
        <div class="mt-24 text-center">
          <div class="inline-block p-1 bg-bg-light rounded-full mb-8">
             <div class="px-8 py-3 bg-white rounded-full border border-gray-100 shadow-sm text-sm text-text-gray font-medium">
               And 15+ more students with distinction scores in multiple subjects.
             </div>
          </div>
          <br />
          <a href={`${base}/contact`} class="btn-gold px-12 py-5 text-lg shadow-xl shadow-accent/20">
            Join the Next Batch of Toppers
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FloatingWhatsApp />
</Layout>
