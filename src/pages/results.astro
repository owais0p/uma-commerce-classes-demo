---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import TopperCard from '../components/TopperCard.astro';

const base = '/uma-commerce-classes-demo';

// Dynamic Topper Data Extraction from Filenames
const topperFiles = [
  "Ravneet Singh Makhija-Accountancy 99-100.png",
  "Ritika Tulsani -Accountancy 99-100.png",
  "Sanika Agarwal-Accountancy 98-100.png",
  "Jayant Jeswani-Accountancy 96-100.png",
  "Jaideep Singh -Accountancy 95-100.png",
  "Krish Garg-Accountancy 94-100.png",
  "Poorva Bhandari -Accountancy 93-100.png",
  "Bhavya Jadon -Accountancy 90-100.png",
  "Laviksha Keswani -Accountancy 91-100.png",
  "Manreet Kaur -Accountancy 91-100.png",
  "Vivek Jethwani -Accountancy 85-100.png"
];

const parseTopper = (filename: string) => {
  const namePart = filename.split('-')[0].trim();
  const rest = filename.split('-').slice(1).join('-');
  const subject = rest.split(/\d/)[0].trim();
  const marksMatch = rest.match(/(\d+-\d+)/);
  const marks = marksMatch ? marksMatch[0].replace('-', '/') : "90+/100";
  
  return {
    name: namePart,
    subject: subject || "Accountancy",
    score: marks,
    image: `${base}/images/toppers/${filename}`,
    isStar: marks.startsWith('99'),
    year: "2026"
  };
};

const allToppers = topperFiles.map(parseTopper);
const starToppers = allToppers.filter(t => t.isStar);
const otherToppers = allToppers.filter(t => !t.isStar);
---

<Layout title="Results" description="Witness the success of Uma Classes students in 12th Board Exams. High-achieving commerce coaching in Kota.">
  <Navbar />
  
  <main class="dark:bg-[#0f1923] transition-colors duration-300">
    <!-- Page Header -->
    <section class="bg-primary text-white py-24 relative overflow-hidden dark:bg-[#0a1628] isolation-auto">
      <div class="absolute inset-0 opacity-10 z-[-1]">
        <div class="absolute top-10 left-10 w-48 h-48 bg-accent rounded-full filter blur-3xl z-[-1]"></div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center relative z-10 space-y-4 animate-on-scroll">
        <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Hall of Fame</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading uppercase tracking-tight">Our <span class="text-accent italic font-serif normal-case">Results</span> 2026</h1>
        <div class="w-20 h-1 bg-accent mx-auto mt-6"></div>
        <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed pt-4">
          Witness the excellence of students who mastered the commerce curriculum under expert guidance.
        </p>
      </div>
    </section>

    <!-- Star Results Spotlight -->
    <section class="section-padding bg-bg-light dark:bg-[#0f1923] isolation-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 space-y-3 animate-on-scroll">
          <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Top Scorers</p>
          <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight dark:text-white transition-colors duration-300">The 99% Achievement</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto animate-on-scroll">
          {starToppers.map(topper => (
            <TopperCard {...topper} />
          ))}
        </div>
        
        <div class="mt-20 bg-white p-10 rounded-2xl shadow-xl border border-gray-100 relative overflow-hidden dark:bg-[#1a2332] dark:border-gray-800 transition-colors duration-300 max-w-4xl mx-auto animate-on-scroll isolation-auto card">
          <div class="absolute top-0 right-0 p-8 text-accent/10 text-8xl z-[-1]">📰</div>
          <div class="relative z-10">
             <p class="text-accent font-bold uppercase tracking-[0.3em] text-[10px] mb-2">Media Recognition</p>
             <h3 class="text-2xl font-bold text-primary font-heading mb-4 dark:text-white transition-colors duration-300">"A Record-Breaking Year in Kota"</h3>
             <p class="text-text-gray leading-relaxed text-lg italic border-l-4 border-accent pl-6 dark:text-gray-400">
               "Uma Classes has once again set the gold standard in coaching. With 15+ students securing 90%+ marks, the institute continues to be the first choice for commerce aspirants."
               <br />
               <span class="block mt-4 text-sm font-bold text-primary dark:text-accent transition-colors duration-300">— Dainik Bhaskar Bureau</span>
             </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Wall of Fame Grid -->
    <section class="section-padding bg-white dark:bg-[#0f1923] transition-colors duration-300 isolation-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 space-y-3">
          <p class="text-accent font-bold uppercase tracking-[0.4em] text-xs">Consistent Excellence</p>
          <h2 class="text-3xl md:text-4xl font-bold text-primary font-heading tracking-tight dark:text-white transition-colors duration-300">Rankers Gallery</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {otherToppers.map(topper => (
            <TopperCard {...topper} />
          ))}
        </div>
        
        <div class="mt-24 text-center">
          <div class="inline-block p-1 bg-bg-light rounded-full mb-8 dark:bg-[#1a2332]">
             <div class="px-8 py-3 bg-white rounded-full border border-gray-100 shadow-sm text-sm text-text-gray font-medium dark:bg-[#0a1628] dark:border-gray-800 dark:text-gray-400">
               And 15+ more students with distinction scores in multiple subjects.
             </div>
          </div>
          <br />
          <a href={`${base}/contact`} class="btn-gold px-12 py-5 text-lg">
            Join the Next Batch of Toppers
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <FloatingWhatsApp />
</Layout>
