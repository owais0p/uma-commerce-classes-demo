---
const { base = '/uma-commerce-classes-demo' } = Astro;
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white pt-10 pb-6 border-t border-white/5 transition-all duration-300 dark:bg-[#0a1628]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- About/Logo -->
      <div class="space-y-4">
        <div>
          <h3 class="text-xl font-medium text-white tracking-tight" style="font-family: 'Playfair Display', serif;">Uma Classes</h3>
          <p class="text-[10px] text-accent font-bold uppercase tracking-[0.3em] mt-1">Elite Commerce Coaching</p>
        </div>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          Empowering the next generation of commerce leaders in Kota through rigorous academic training and dedicated mentorship.
        </p>
        <div class="flex space-x-6 pt-2">
          <a href="https://www.instagram.com/umacommerceclasses" 
             target="_blank">
            <svg xmlns="http://www.w3.org/2000/svg" 
                 width="24" height="24" viewBox="0 0 24 24" 
                 fill="#c9a84c">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 
              3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 
              1.645.069 4.849 0 3.205-.012 3.584-.069 4.849
              -.149 3.225-1.664 4.771-4.919 4.919-1.266.058
              -1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07
              -3.26-.149-4.771-1.699-4.919-4.92-.058-1.265
              -.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849
              .149-3.227 1.664-4.771 4.919-4.919 1.266-.057 
              1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 
              7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 
              0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 
              2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 
              24c3.259 0 3.668-.014 4.948-.072 4.354-.2 
              6.782-2.618 6.979-6.98.059-1.28.073-1.689
              .073-4.948 0-3.259-.014-3.667-.072-4.947-.196
              -4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 
              0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 
              6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 
              010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 
              1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Elite Links -->
      <div>
        <h4 class="text-xs font-bold text-accent uppercase tracking-[0.2em] mb-6">Navigation</h4>
        <ul class="space-y-3 text-white/50 text-sm">
          <li><a href={`${base}/`} class="hover:text-white transition-colors">Home</a></li>
          <li><a href={`${base}/courses`} class="hover:text-white transition-colors">Courses</a></li>
          <li><a href={`${base}/results`} class="hover:text-white transition-colors">Board Results</a></li>
          <li><a href={`${base}/about`} class="hover:text-white transition-colors">The Institute</a></li>
          <li><a href={`${base}/contact`} class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-xs font-bold text-accent uppercase tracking-[0.2em] mb-6">Connect</h4>
        <ul class="space-y-4 text-white/50 text-sm">
          <li class="flex items-start space-x-4">
            <span class="text-accent text-lg mt-0.5">📍</span>
            <a 
              href="https://www.google.com/maps/place/Uma+Commerce+Classes/@25.219335,75.873195,17z/data=!3m1!4b1!4m6!3m5!1s0x396f9a5e8c4c8a3b:0x219f64e0442d9b7d!8m2!3d25.219335!4d75.873195!16s%2Fg%2F11c203fphn" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="hover:text-white transition-colors leading-relaxed"
            >
              Uma Grah, New Post Office Road, Kota, Rajasthan
            </a>
          </li>
          <li class="flex items-center space-x-4">
            <span class="text-accent text-lg">📞</span>
            <div class="flex flex-col">
              <a href="tel:+919351595412" class="hover:text-white transition-colors">+91 93515 95412</a>
              <a href="tel:+919414454052" class="hover:text-white transition-colors">+91 94144 54052</a>
            </div>
          </li>
        </ul>
      </div>

      <!-- Location Strip -->
      <div>
        <h4 class="text-xs font-bold text-accent uppercase tracking-[0.2em] mb-6">Visit Us</h4>
        <div class="aspect-video bg-white/5 rounded-xl overflow-hidden border border-white/10 relative group">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3610.6445100000003!2d75.873195!3d25.219335!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x396f9a5e8c4c8a3b%3A0x219f64e0442d9b7d!2sUma%20Commerce%20Classes!5e0!3m2!1sen!2sin!4v1717112520000!5m2!1sen!2sin" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="filter contrast-[1.1] dark:invert dark:hue-rotate-180 dark:brightness-[0.8]"
          ></iframe>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-white/30 text-[10px] uppercase tracking-widest">
        &copy; {currentYear} Uma Classes.
      </div>
      <div class="flex items-center space-x-8 text-white/30 text-[10px] uppercase tracking-widest">
        <a href="#" class="hover:text-accent transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-accent transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
