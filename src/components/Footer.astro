---
const { base = '/uma-commerce-classes-demo' } = Astro;
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-dark text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- About/Logo -->
      <div class="space-y-4">
        <h3 class="text-xl font-bold text-secondary tracking-tight">UMA COMMERCE CLASSES</h3>
        <p class="text-white/70 text-sm leading-relaxed">
          Providing high-quality commerce education for 11th and 12th standard students in Kota. Our mission is to transform students into toppers with conceptual clarity and rigorous practice.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="text-white/60 hover:text-secondary"><span class="sr-only">Facebook</span>FB</a>
          <a href="#" class="text-white/60 hover:text-secondary"><span class="sr-only">Instagram</span>IG</a>
          <a href="#" class="text-white/60 hover:text-secondary"><span class="sr-only">YouTube</span>YT</a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-bold mb-6 border-b border-secondary/30 pb-2 inline-block">Quick Links</h4>
        <ul class="space-y-3 text-white/70">
          <li><a href={`${base}/`} class="hover:text-secondary transition-colors">Home</a></li>
          <li><a href={`${base}/courses`} class="hover:text-secondary transition-colors">Courses</a></li>
          <li><a href={`${base}/results`} class="hover:text-secondary transition-colors">Results</a></li>
          <li><a href={`${base}/about`} class="hover:text-secondary transition-colors">About Us</a></li>
          <li><a href={`${base}/contact`} class="hover:text-secondary transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-lg font-bold mb-6 border-b border-secondary/30 pb-2 inline-block">Contact Us</h4>
        <ul class="space-y-4 text-white/70">
          <li class="flex items-start space-x-3">
            <span class="text-secondary">📍</span>
            <span>Uma Grah, New Post Office Road, Kota, Rajasthan</span>
          </li>
          <li class="flex items-center space-x-3">
            <span class="text-secondary">📞</span>
            <a href="tel:+919351595412" class="hover:text-secondary">+91 93515 95412</a>
          </li>
          <li class="flex items-center space-x-3">
            <span class="text-secondary">📞</span>
            <a href="tel:+919414454052" class="hover:text-secondary">+91 94144 54052</a>
          </li>
          <li class="flex items-center space-x-3">
            <span class="text-secondary">📧</span>
            <a href="mailto:info@umacommerceclasses.com" class="hover:text-secondary">info@umacommerce.com</a>
          </li>
        </ul>
      </div>

      <!-- Location Map -->
      <div>
        <h4 class="text-lg font-bold mb-6 border-b border-secondary/30 pb-2 inline-block">Find Us</h4>
        <div class="aspect-video bg-white/10 rounded-lg overflow-hidden flex items-center justify-center border border-white/10 group">
          <span class="text-white/30 text-xs italic group-hover:text-secondary transition-colors text-center px-4">Google Maps Placeholder<br>(Uma Grah, Kota)</span>
        </div>
        <p class="mt-3 text-xs text-white/40 italic">New Post Office Road, Kota</p>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10 text-center text-white/40 text-xs">
      <p>&copy; {currentYear} Uma Commerce Classes, Kota. All Rights Reserved.</p>
      <p class="mt-2">Designed for Excellence.</p>
    </div>
  </div>
</footer>
