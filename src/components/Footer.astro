---
const { base = '/uma-commerce-classes-demo' } = Astro;
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white pt-24 pb-12 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      <!-- About/Logo -->
      <div class="space-y-6">
        <div>
          <h3 class="text-xl font-bold text-white tracking-tight font-heading">UMA COMMERCE CLASSES</h3>
          <p class="text-[10px] text-accent font-bold uppercase tracking-[0.3em] mt-1">Elite Commerce Coaching</p>
        </div>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          Empowering the next generation of commerce leaders in Kota through rigorous academic training and elite mentorship.
        </p>
        <div class="flex space-x-6 pt-2">
          <a href="#" class="text-white/30 hover:text-accent transition-colors"><span class="sr-only">Facebook</span>FB</a>
          <a href="#" class="text-white/30 hover:text-accent transition-colors"><span class="sr-only">Instagram</span>IG</a>
          <a href="#" class="text-white/30 hover:text-accent transition-colors"><span class="sr-only">LinkedIn</span>LI</a>
        </div>
      </div>

      <!-- Elite Links -->
      <div>
        <h4 class="text-sm font-bold text-accent uppercase tracking-[0.2em] mb-8">Navigation</h4>
        <ul class="space-y-4 text-white/50 text-sm">
          <li><a href={`${base}/`} class="hover:text-white transition-colors">Home</a></li>
          <li><a href={`${base}/courses`} class="hover:text-white transition-colors">Elite Courses</a></li>
          <li><a href={`${base}/results`} class="hover:text-white transition-colors">Board Results</a></li>
          <li><a href={`${base}/about`} class="hover:text-white transition-colors">The Institute</a></li>
          <li><a href={`${base}/contact`} class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-sm font-bold text-accent uppercase tracking-[0.2em] mb-8">Connect</h4>
        <ul class="space-y-6 text-white/50 text-sm">
          <li class="flex items-start space-x-4">
            <span class="text-accent text-lg mt-0.5">📍</span>
            <span class="leading-relaxed">Uma Grah, New Post Office Road, Kota, Rajasthan</span>
          </li>
          <li class="flex items-center space-x-4">
            <span class="text-accent text-lg">📞</span>
            <a href="tel:+919351595412" class="hover:text-white transition-colors">+91 93515 95412</a>
          </li>
          <li class="flex items-center space-x-4">
            <span class="text-accent text-lg">✉️</span>
            <a href="mailto:info@umacommerceclasses.com" class="hover:text-white transition-colors">info@umacommerce.com</a>
          </li>
        </ul>
      </div>

      <!-- Location Strip -->
      <div>
        <h4 class="text-sm font-bold text-accent uppercase tracking-[0.2em] mb-8">Visit Us</h4>
        <div class="aspect-video bg-white/5 rounded-xl overflow-hidden flex items-center justify-center border border-white/10 group cursor-pointer hover:border-accent/30 transition-colors">
          <div class="text-center p-4">
             <span class="text-white/20 text-[10px] uppercase tracking-widest group-hover:text-accent transition-colors">View Map Location</span>
          </div>
        </div>
        <p class="mt-4 text-[10px] text-white/30 italic">New Post Office Road Area, Kota</p>
      </div>
    </div>

    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-white/30 text-[10px] uppercase tracking-widest">
        &copy; {currentYear} Uma Commerce Classes. All Excellence Reserved.
      </div>
      <div class="flex items-center space-x-8 text-white/30 text-[10px] uppercase tracking-widest">
        <a href="#" class="hover:text-accent transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-accent transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
