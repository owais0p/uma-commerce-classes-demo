---
interface Props {
  name: string;
  score: string;
  subject: string;
  year: string;
  isStar?: boolean;
}

const { name, score, subject, year, isStar = false } = Astro.props;
---

<div class={`relative bg-white rounded-2xl overflow-hidden shadow-lg border-2 ${isStar ? 'border-secondary' : 'border-gray-50'} p-6 transition-transform hover:scale-[1.02]`}>
  {isStar && (
    <div class="absolute top-0 right-0 bg-secondary text-primary px-4 py-1 font-bold text-xs uppercase tracking-widest rounded-bl-xl">
      Star Result
    </div>
  )}
  
  <div class="flex items-center space-x-4 mb-4">
    <div class={`w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-bold ${isStar ? 'bg-primary' : 'bg-gray-400'}`}>
      {name.charAt(0)}
    </div>
    <div>
      <h3 class="text-xl font-bold text-primary leading-tight">{name}</h3>
      <p class="text-sm text-gray-500">{year} Board Exams</p>
    </div>
  </div>
  
  <div class="space-y-2">
    <div class="flex justify-between items-end border-b border-gray-100 pb-2">
      <span class="text-sm text-gray-600 font-medium">{subject}</span>
      <span class="text-3xl font-black text-primary">{score}</span>
    </div>
    <div class="pt-2">
      <div class="w-full bg-gray-100 h-2 rounded-full overflow-hidden">
        <div class={`h-full ${isStar ? 'bg-secondary' : 'bg-primary'}`} style={`width: ${score.split('/')[0]}%`}></div>
      </div>
    </div>
  </div>
  
  {isStar && (
    <p class="mt-4 text-xs font-bold text-primary/60 italic text-center">
      "Hard work always pays off with right guidance!"
    </p>
  )}
</div>
