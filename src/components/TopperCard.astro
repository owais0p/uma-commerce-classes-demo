---
interface Props {
  name: string;
  score: string;
  subject: string;
  year: string;
  image?: string;
  isStar?: boolean;
}

const { name, score, subject, year, image, isStar = false } = Astro.props;
---

<div class={`group relative glass rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-[0_30px_60px_-10px_rgba(18,33,56,0.2)] dark:hover:shadow-[0_30px_60px_-10px_rgba(201,168,76,0.1)] transition-all duration-700 border border-white/10 card ${isStar ? 'ring-2 ring-accent ring-offset-8 dark:ring-offset-[#080c14]' : ''}`}>
  <!-- Student Image -->
  <div class="aspect-[4/5] overflow-hidden bg-primary/5 relative">
    {image ? (
      <img 
        src={image} 
        alt={name} 
        class="w-full h-full object-cover grayscale brightness-110 contrast-105 group-hover:grayscale-0 group-hover:scale-110 transition-all duration-1000 ease-out"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-6xl font-heading text-accent/20">
        {name.charAt(0)}
      </div>
    )}
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>

    <!-- Achievement Badge -->
    <div class="absolute top-6 right-6 glass px-4 py-2 rounded-full shadow-2xl border border-white/20">
      <p class="text-xs font-bold text-accent tracking-widest">{score}</p>
    </div>
    
    {isStar && (
      <div class="absolute top-6 left-6 bg-accent text-white px-4 py-2 rounded-full text-[9px] font-bold uppercase tracking-[0.2em] shadow-2xl">
        Elite Merit
      </div>
    )}

    <!-- Name Overlay on Image for premium feel -->
    <div class="absolute bottom-8 left-8 right-8">
      <h3 class="text-2xl font-bold text-white font-heading tracking-tight mb-1 group-hover:text-accent transition-colors duration-500">{name}</h3>
      <p class="text-[10px] font-bold text-white/70 uppercase tracking-[0.3em]">{subject} • {year}</p>
    </div>
  </div>

  <!-- Subtle bottom indicator -->
  <div class="h-1.5 w-0 group-hover:w-full bg-accent transition-all duration-700"></div>
</div>
