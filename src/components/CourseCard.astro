---
interface Props {
  title: string;
  classes: string;
  description: string;
  features: string[];
  icon: string;
}

const { title, classes, description, features, icon } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-500 group flex flex-col h-full">
  <div class="p-10 flex-grow flex flex-col">
    <div class="flex items-start justify-between mb-8">
      <div class="w-16 h-16 bg-bg-light rounded-2xl flex items-center justify-center text-3xl group-hover:bg-accent group-hover:text-white transition-all duration-500 shadow-inner">
        {icon}
      </div>
      <div class="text-right">
        <p class="text-[10px] font-bold text-accent uppercase tracking-widest mb-1">Premium Program</p>
        <p class="text-xs font-bold text-primary">{classes}</p>
      </div>
    </div>
    
    <h3 class="text-2xl font-bold text-primary mb-4 font-heading group-hover:text-accent transition-colors tracking-tight">{title}</h3>
    <p class="text-text-gray mb-8 leading-relaxed text-sm">
      {description}
    </p>
    
    <div class="space-y-4 mb-10 flex-grow">
      {features.map((feature) => (
        <div class="flex items-center space-x-3 text-[13px] text-text-dark font-medium">
          <span class="text-accent">✦</span>
          <span>{feature}</span>
        </div>
      ))}
    </div>
    
    <a href="/uma-commerce-classes-demo/contact" class="w-full text-center py-4 rounded-lg font-bold text-xs uppercase tracking-widest border border-gray-100 group-hover:border-accent group-hover:bg-accent group-hover:text-white transition-all duration-300">
      Enquire Now
    </a>
  </div>
</div>
