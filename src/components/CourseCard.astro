---
interface Props {
  title: string;
  classes: string;
  description: string;
  features: string[];
  icon: string;
}

const { title, classes, description, features, icon } = Astro.props;
---

<div class="glass rounded-[2.5rem] shadow-sm hover:shadow-[0_20px_50px_rgba(18,33,56,0.1)] dark:hover:shadow-[0_20px_50px_rgba(201,168,76,0.05)] transition-all duration-500 group flex flex-col h-full border border-white/10 relative overflow-hidden card">
  <!-- Decorative Backdrop -->
  <div class="absolute -top-20 -right-20 w-40 h-40 bg-accent/5 rounded-full blur-3xl group-hover:bg-accent/10 transition-colors duration-500 z-[-1]"></div>
  
  <div class="p-10 flex-grow flex flex-col">
    <div class="flex items-start justify-between mb-10">
      <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-500 shadow-inner">
        {icon}
      </div>
      <div class="text-right">
        <p class="text-[9px] font-bold text-accent uppercase tracking-[0.2em] mb-1">Commerce Program</p>
        <p class="text-[11px] font-bold text-primary/60 dark:text-gray-400 uppercase tracking-widest">{classes}</p>
      </div>
    </div>
    
    <div class="space-y-4 mb-8">
      <h3 class="text-3xl font-bold text-primary font-heading group-hover:text-accent transition-colors duration-500 dark:text-white leading-none">{title}</h3>
      <div class="h-0.5 w-8 bg-accent/30 group-hover:w-full transition-all duration-700"></div>
    </div>

    <p class="text-text-gray/80 mb-8 leading-relaxed text-sm dark:text-gray-400 font-medium">
      {description}
    </p>
    
    <div class="space-y-4 mb-10 flex-grow">
      {features.map((feature) => (
        <div class="flex items-center space-x-3 text-[12px] text-text-dark font-bold dark:text-gray-300">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          <span class="uppercase tracking-widest opacity-70">{feature}</span>
        </div>
      ))}
    </div>
    
    <a href="/uma-commerce-classes-demo/contact" class="btn-gold w-full text-center !py-4 text-[10px] shadow-lg shadow-accent/10">
      Enquire For Syllabus
    </a>
  </div>
</div>
