---
interface Props {
  title: string;
  classes: string;
  description: string;
  features: string[];
  icon: string;
}

const { title, classes, description, features, icon } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 hover:shadow-2xl transition-all group flex flex-col h-full">
  <div class="bg-primary p-6 text-white relative overflow-hidden">
    <div class="absolute -right-4 -bottom-4 text-white/10 group-hover:scale-110 transition-transform duration-500">
      <span class="text-8xl">{icon}</span>
    </div>
    <div class="relative z-10">
      <h3 class="text-2xl font-bold mb-1 tracking-tight text-secondary uppercase">{title}</h3>
      <p class="text-sm font-medium text-white/80">{classes}</p>
    </div>
  </div>
  <div class="p-8 flex-grow flex flex-col">
    <p class="text-gray-600 mb-6 leading-relaxed">
      {description}
    </p>
    <div class="space-y-3 mb-8 flex-grow">
      {features.map((feature) => (
        <div class="flex items-start space-x-3 text-sm">
          <span class="text-secondary mt-1">✔</span>
          <span class="text-gray-700">{feature}</span>
        </div>
      ))}
    </div>
    <a href="/uma-commerce-classes-demo/contact" class="inline-block text-center bg-gray-50 text-primary py-3 rounded-xl font-bold hover:bg-secondary transition-colors border border-gray-100">
      Enquire Now
    </a>
  </div>
</div>
