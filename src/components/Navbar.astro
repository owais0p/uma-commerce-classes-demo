---
const { base = '/uma-commerce-classes-demo' } = Astro;
---

<nav id="main-nav" class="fixed top-0 left-0 w-full z-50 transition-all duration-700 py-4">
  <div class="max-w-7xl mx-auto px-6 sm:px-8">
    <div class="glass rounded-[2rem] px-8 py-3 flex justify-between items-center transition-all duration-500 border border-white/10 shadow-2xl">
      <!-- Logo and Name -->
      <div class="flex items-center space-x-3">
        <a href={`${base}/`} class="flex flex-col group">
          <span class="text-xl md:text-2xl font-bold text-primary leading-tight group-hover:text-accent transition-all duration-500 dark:text-white" style="font-family: 'Playfair Display', serif;">Uma Classes</span>
          <div class="h-0.5 w-0 group-hover:w-full bg-accent transition-all duration-500"></div>
          <span class="text-[9px] tracking-[0.3em] uppercase font-bold text-text-gray/80 dark:text-gray-400 mt-1">Excellence as a Habit</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-10">
        {[
          { name: 'Home', link: '/' },
          { name: 'Courses', link: '/courses' },
          { name: 'Results', link: '/results' },
          { name: 'About', link: '/about' },
          { name: 'Contact', link: '/contact' }
        ].map(item => (
          <a href={`${base}${item.link}`} class="relative text-[11px] font-bold uppercase tracking-widest text-primary/70 hover:text-accent transition-colors dark:text-white/70 dark:hover:text-accent group">
            {item.name}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </div>

      <!-- Tools -->
      <div class="flex items-center space-x-6">
        <!-- Theme Toggle -->
        <button 
          id="theme-toggle" 
          class="p-2 cursor-pointer flex items-center justify-center rounded-full hover:bg-accent/10 transition-colors" 
          aria-label="Toggle Dark Mode"
        >
          <i data-lucide="sun" class="hidden dark:block w-4 h-4 text-accent"></i>
          <i data-lucide="moon" class="block dark:hidden w-4 h-4 text-accent"></i>
        </button>

        <a href={`${base}/contact`} class="hidden lg:block btn-gold !py-2.5 !px-6 text-[10px]">
          Demo Class
        </a>

        <!-- Mobile Menu Trigger -->
        <button id="mobile-menu-button" class="md:hidden text-primary dark:text-white p-2" aria-label="Toggle Menu">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 dark:bg-gray-900 dark:border-gray-800">
    <div class="px-4 pt-2 pb-6 space-y-1 sm:px-3 flex flex-col items-center text-center">
      <a href={`${base}/`} class="block px-3 py-3 text-base font-medium hover:bg-bg-light rounded-md w-full dark:text-gray-300 dark:hover:bg-gray-800">Home</a>
      <a href={`${base}/courses`} class="block px-3 py-3 text-base font-medium hover:bg-bg-light rounded-md w-full dark:text-gray-300 dark:hover:bg-gray-800">Courses</a>
      <a href={`${base}/results`} class="block px-3 py-3 text-base font-medium hover:bg-bg-light rounded-md w-full dark:text-gray-300 dark:hover:bg-gray-800">Results</a>
      <a href={`${base}/about`} class="block px-3 py-3 text-base font-medium hover:bg-bg-light rounded-md w-full dark:text-gray-300 dark:hover:bg-gray-800">About</a>
      <a href={`${base}/contact`} class="block px-3 py-3 text-base font-medium hover:bg-bg-light rounded-md w-full dark:text-gray-300 dark:hover:bg-gray-800">Contact</a>
      <div class="pt-4 flex flex-col items-center space-y-3 w-full overflow-hidden">
        <a href="tel:+919351595412" class="text-lg font-bold flex items-center gap-2 dark:text-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          93515 95412
        </a>
        <a href={`${base}/contact`} class="btn-gold w-full max-w-xs">
          Free Demo Class
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Mobile Menu
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const path = document.getElementById('menu-icon-path');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    if (menu?.classList.contains('hidden')) {
      path?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      path?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });

  // Dark Mode
  const themeToggle = document.getElementById('theme-toggle');
  const themeToggleMobile = document.getElementById('theme-toggle-mobile');

  const handleToggle = () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };

  themeToggle?.addEventListener('click', handleToggle);
  themeToggleMobile?.addEventListener('click', handleToggle);

  // Navbar Scroll Logic
  const mainNav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      mainNav?.classList.remove('bg-transparent');
      mainNav?.classList.add('bg-white', 'shadow-md', 'dark:bg-[#0f1923]', 'dark:border-gray-800');
    } else {
      mainNav?.classList.add('bg-transparent');
      mainNav?.classList.remove('bg-white', 'shadow-md', 'dark:bg-[#0f1923]', 'dark:border-gray-800');
    }
  });

  // Initialize Lucide Icons
  // @ts-ignore
  lucide.createIcons();
</script>
