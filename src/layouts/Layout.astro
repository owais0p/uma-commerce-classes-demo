			   width="28" height="28" viewBox="0 0 24 24" 
			   fill="white">
			<path d="M17.472 14.382c-.297-.149-1.758-.867
			-2.03-.967-.273-.099-.471-.148-.67.15-.197.297
			-.767.966-.94 1.164-.173.199-.347.223-.644.075
			-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48
			-1.761-1.653-2.059-.173-.297-.018-.458.13-.606
			.134-.133.298-.347.446-.52.149-.174.198-.298
