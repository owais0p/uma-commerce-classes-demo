			-.669-1.612-.916-2.207-.242-.579-.487-.5-.669
			-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074
			-.792.372-.272.297-1.04 1.016-1.04 2.479 0 
			1.462 1.065 2.875 1.213 3.074.149.198 2.096 
			3.2 5.077 4.487.709.306 1.262.489 1.694.625
